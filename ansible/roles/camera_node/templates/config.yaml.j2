camera_id: "{{ camera_id }}"
listen_host: "{{ openscan_camera_node_listen_host }}"
listen_port: {{ openscan_camera_node_listen_port }}
output_root: "{{ openscan_sessions_root }}"
camera_control_policy:
  use_calibration_suggestions: {{ openscan_camera_control_policy_use_calibration_suggestions | default(false) | bool | lower }}
  apply_suggestions_to_recording: {{ openscan_camera_control_policy_apply_suggestions_to_recording | default(false) | bool | lower }}
profile_overrides:
{{ openscan_camera_node_profile_overrides | default({}) | to_nice_yaml(indent=2, sort_keys=False) | indent(2, true) }}
